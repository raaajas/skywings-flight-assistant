{
  "name": "flight-assistant",
  "private": true,
  "workspaces": [
    "apps/web",
    "functions"
  ],
  "scripts": {
    "dev:web": "npm run dev --workspace=apps/web",
    "build:web": "npm run build --workspace=apps/web",
    "build:functions": "npm run build --workspace=functions",
    "build": "npm run build:web && npm run build:functions",
    "emulators": "powershell -ExecutionPolicy Bypass -File scripts/start-emulators.ps1",
    "emulators:stop": "powershell -ExecutionPolicy Bypass -File scripts/stop-emulators.ps1",
    "seed:local": "node scripts/seed-local.mjs",
    "dev": "npm run build:functions && concurrently \"npm run emulators\" \"npm run dev:web\"",
    "deploy": "firebase deploy",
    "tunnel": "node scripts/tunnel-manager.mjs"

  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "firebase-tools": "^15.22.0",
    "vercel": "^54.15.1"
  }
}
