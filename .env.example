# Firebase web app config (apps/web/.env)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=
VITE_FIREBASE_APPCHECK_SITE_KEY=

# Cloud Functions (functions/.secret.local for emulators)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
SEED_SECRET=dev-seed-secret

# Local dev quick start:
# 1. npm install && npm run build:functions
# 2. npm run emulators   (requires Java 21+)
# 3. npm run seed:local
# 4. npm run dev:web     -> http://localhost:5173
# 5. Add GEMINI_API_KEY to functions/.secret.local for AI chat + embeddings
# 6. Emulator UI: http://127.0.0.1:4000
